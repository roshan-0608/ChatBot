# --- Frontend environment variables ---
# Vite exposes only variables prefixed with VITE_ to the browser,
# and they are baked in at BUILD time.
#
# Local dev does NOT need this file (api.js falls back to localhost:8000).
# On Vercel, set VITE_API_URL in Project Settings > Environment Variables.

# Full base URL of the deployed backend API (include /api/v1, no trailing slash)
# Example: https://your-backend.onrender.com/api/v1
VITE_API_URL=https://your-backend.onrender.com/api/v1
