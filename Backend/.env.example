# --- Backend environment variables ---
# Copy this file to `.env` for local dev, and set the same keys in the
# Render dashboard (Environment tab) for production.

# Server
PORT=8000
NODE_ENV=development            # set to "production" on Render

# Database (MongoDB Atlas connection string)
MONGODB_URL=your_mongodb_atlas_connection_string

# Allowed frontend origin for CORS (no trailing slash)
# Local:      http://localhost:5173
# Production: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# JWT secrets (use long random strings in production)
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=10d

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
